; Stage the servable assets (JS bundle + page) side by side in the build dir,
; so `dune build @dashboard` produces a directory the exchange server can point
; `-dashboard-dir` at.

(rule
 (alias dashboard)
 (deps index.html main.bc.js)
 (action (progn)))
